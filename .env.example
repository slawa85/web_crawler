# Database connection (required)
DATABASE_URL=postgres://crawler:crawlerpass@localhost:5432/crawlerdb

# Crawler settings
SEED_URL=https://ipfabric.io/
WORKER_COUNT=5
CRAWL_DELAY_MS=1000
REQUEST_TIMEOUT_MS=10000
MAX_DEPTH=10
MAX_PAGES=10000
MAX_RESPONSE_BYTES=5242880
STALLED_TIMEOUT_MINUTES=5

# Logging
LOG_LEVEL=info

# Node environment (set to 'production' to disable pino-pretty)
NODE_ENV=development
